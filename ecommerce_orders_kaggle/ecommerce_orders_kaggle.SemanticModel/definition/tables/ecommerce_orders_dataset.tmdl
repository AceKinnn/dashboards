	column 'Age Group' = ```
			
			SWITCH(
			    TRUE(),
			    'ecommerce_orders_dataset'[Customer_Age] <= 25, "18-25 (Young Adult)",
			    'ecommerce_orders_dataset'[Customer_Age] >= 26 && 'ecommerce_orders_dataset'[Customer_Age] <= 45, "26-45 (Adult)",
			    'ecommerce_orders_dataset'[Customer_Age] >= 46 && 'ecommerce_orders_dataset'[Customer_Age] <= 60, "46-60 (Middle Age)",
			    'ecommerce_orders_dataset'[Customer_Age] >= 61, "61-75 (Senior)",
			    "Blank"
			)
			
			```
		lineageTag: 8522bc59-7092-4afc-b99f-26267f0bc96f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

