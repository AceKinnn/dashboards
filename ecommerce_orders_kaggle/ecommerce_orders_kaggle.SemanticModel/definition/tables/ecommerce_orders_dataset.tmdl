table ecommerce_orders_dataset
	lineageTag: 07a566bd-c7a0-45b4-92ea-4654ef317e04

	measure 'Overall Profit Margin %' = DIVIDE([Total Profit], [Total Revenue], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 37668775-4ff7-4eed-a29b-a426fbbe20c8

	measure 'Total Revenue' = SUM('ecommerce_orders_dataset'[Order_Amount])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 242e056d-a203-41bd-8cbe-b64e7f7e38dc

	measure 'Total Profit' = SUM('ecommerce_orders_dataset'[Profit_Amount])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: f169e03d-f082-4f1f-a63a-d186cd04f5fc

	measure 'Total Orders' = DISTINCTCOUNT('ecommerce_orders_dataset'[Order_ID])
		formatString: 0
		lineageTag: f25a383c-da1a-49d6-97fd-c4e6161153b4

	measure 'Average Order Value (AOV)' = DIVIDE([Total Revenue], [Total Orders], 0)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: aeede025-b6f2-4bc8-a19f-ae328a812eeb

	measure 'Return Rate %' = DIVIDE(CALCULATE([Total Orders], 'ecommerce_orders_dataset'[Returned] = "Yes"), [Total Orders], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 317e31e7-68c5-40b9-9a95-e8f24d785b33

	measure 'Net Revenue' = [Total Revenue] * (1 - [Return Rate %])
		lineageTag: 38006fd4-abde-446b-b473-1cc72bf9476c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Profit Forecast' = ```
			
			VAR LastActualDate = MAX('ecommerce_orders_dataset'[Order_Date])
			VAR CurrentDate = MAX('DateTable'[Date])
			VAR ActualProfit = [Total Profit]
			// This assumes 10% growth compared to the exact same month last year
			VAR ForecastedProfit = CALCULATE([Total Profit], SAMEPERIODLASTYEAR('DateTable'[Date])) * 1.10 
			
			RETURN
			IF(
			    CurrentDate <= LastActualDate, 
			    ActualProfit, 
			    ForecastedProfit
			)
			```
		lineageTag: 63c0d752-4a60-4188-a83d-1668829dfaba

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Unique Customers' = DISTINCTCOUNT('ecommerce_orders_dataset'[Customer_ID])
		formatString: 0
		lineageTag: a30043c9-1565-4cc4-b1c2-307c66c6fb6d

	measure 'Average CLV' = ```
			
			AVERAGEX(
			    VALUES('ecommerce_orders_dataset'[Customer_ID]), 
			    CALCULATE(MAX('ecommerce_orders_dataset'[Customer_Lifetime_Value]))
			)
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 733c99fb-4ccd-4342-bff2-51e7e8963e0a

	measure 'Total CLV' = ```
			
			SUMX(
			    VALUES('ecommerce_orders_dataset'[Customer_ID]), 
			    CALCULATE(MAX('ecommerce_orders_dataset'[Customer_Lifetime_Value]))
			)
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: b80a1961-fefb-4abb-b3fb-acde5e57299a

	measure 'Average Review Rating' = AVERAGE('ecommerce_orders_dataset'[Review_Rating])
		lineageTag: 9cbdb607-f164-43f1-b152-e37a2938661a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Average Review Rating per Customer' =
			
			AVERAGEX(
			    VALUES('ecommerce_orders_dataset'[Customer_ID]),
			    CALCULATE(AVERAGE('ecommerce_orders_dataset'[Review_Rating]))
			)
		lineageTag: 0330ca72-dcd4-48d7-990f-ba227df865a5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

